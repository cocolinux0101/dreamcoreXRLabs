# ─── OS artifacts ──────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
$RECYCLE.BIN/
._*

# ─── Editors / IDEs ────────────────────────────────────────────
.vscode/
.idea/
.vs/
*.swp
*.swo
*~
.project
.settings/

# ─── Netlify local state ───────────────────────────────────────
# CLI cache, local dev server state, function bundles
.netlify/

# ─── Secrets / env files ───────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ─── Logs & temp files ─────────────────────────────────────────
*.log
*.tmp
*.bak
*.orig

# ─── Python http.server leftovers (local preview) ──────────────
__pycache__/
*.pyc

# ─── Node tooling (if added later) ─────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json.bak

# ─── Archives / accidental drops ───────────────────────────────
*.zip
*.tar.gz
*.7z
